{% render 'partials/head.liquid', overzicht: true %}
</header>

<section class="ins-container">
  <nav class="ins-controls">
    <form action="/instrumenten" method="GET" class="filter-form">

        <label class="filters">
          {% comment %} Instrument {% endcomment %}
          <select name="instrument" onchange="this.form.submit()" class="ins-btn">
            <option
              value=""
              {% if not soort %}
                selected
              {% endif %}
            >
              Alle instrumenten
            </option>
            <option
              value="Gitaar akoestisch"
              {% if soort == 'Gitaar akoestisch' %}
                selected
              {% endif %}
            >
              Gitaar
            </option>
            <option
              value="Gitaar driekwart"
              {% if soort == 'Gitaar driekwart' %}
                selected
              {% endif %}
            >
              Gitaar 3/4
            </option>
            <option
              value="Basgitaar"
              {% if soort == 'Basgitaar' %}
                selected
              {% endif %}
            >
              Basgitaar
            </option>
            <option
              value="Elektrische gitaar"
              {% if soort == 'Elektrische gitaar' %}
                selected
              {% endif %}
            >
              Elektrische gitaar
            </option>
            <option
              value="Cello"
              {% if soort == 'Cello' %}
                selected
              {% endif %}
            >
              Cello
            </option>
            <option
              value="Viool"
              {% if soort == 'Viool' %}
                selected
              {% endif %}
            >
              Viool
            </option>
            <option
              value="Ukelele"
              {% if soort == 'Ukelele' %}
                selected
              {% endif %}
            >
              Ukelele
            </option>
            <option
              value="Keyboard"
              {% if soort == 'Keyboard' %}
                selected
              {% endif %}
            >
              Keyboard
            </option>
            <option
              value="Blokfluit"
              {% if soort == 'Blokfluit' %}
                selected
              {% endif %}
            >
              Blokfluit
            </option>
            <option
              value="Dwarsfluit"
              {% if soort == 'Dwarsfluit' %}
                selected
              {% endif %}
            >
              Dwarsfluit
            </option>
            <option
              value="Darbukha"
              {% if soort == 'Darbukha' %}
                selected
              {% endif %}
            >
              Darbukha
            </option>
            <option
              value="Hoorn"
              {% if soort == 'Hoorn' %}
                selected
              {% endif %}
            >
              Hoorn
            </option>
            <option
              value="Altsaxofoon"
              {% if soort == 'Altsaxofoon' %}
                selected
              {% endif %}
            >
              Altsaxofoon
            </option>
            <option
              value="Tenorsaxofoon"
              {% if soort == 'Tenorsaxofoon' %}
