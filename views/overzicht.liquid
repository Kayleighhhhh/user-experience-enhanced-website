              {% endif %}
            >
              Tenorsaxofoon
            </option>
            <option
              value="Baritonsaxofoon"
              {% if soort == 'Baritonsaxofoon' %}
                selected
              {% endif %}
            >
              Baritonsaxofoon
            </option>
            <option
              value="Trompet"
              {% if soort == 'Trompet' %}
                selected
              {% endif %}
            >
              Trompet
            </option>
            <option
              value="Trombone"
              {% if soort == 'Trombone' %}
                selected
              {% endif %}
            >
              Trombone
            </option>
            <option
              value="Cajon"
              {% if soort == 'Cajon' %}
                selected
              {% endif %}
            >
              Cajon
            </option>
            <option
              value="Hobo"
              {% if soort == 'Hobo' %}
                selected
              {% endif %}
            >
              Hobo
            </option>
            <option
              value="Accordeon"
              {% if soort == 'Accordeon' %}
                selected
              {% endif %}
            >
              Accordeon
            </option>
            <option
              value="Bugel"
              {% if soort == 'Bugel' %}
                selected
              {% endif %}
            >
              Bugel
            </option>
            <option
              value="Harp"
              {% if soort == 'Harp' %}
                selected
              {% endif %}
            >
              Harp
            </option>
            <option
              value="Klarinet"
              {% if soort == 'Klarinet' %}
                selected
              {% endif %}
            >
              Klarinet
            </option>
          </select>
        </label>
    </form>

    <a href="/instrumenten/nieuw" class="ins-btn">Nieuw instrument</a>

    {% comment %} <label class="ins-switch">
      <input type="checkbox" checked>
      <span class="ins-slider"></span>
    </label> {% endcomment %}
  </nav>

  <table class="ins-list">
  <thead class="ins-list-head">
    <tr>
      <th class="ins-title">Instrumenten</th>
      <th class="ins-title">Status</th>
      <th class="ins-title">Actie</th>
    </tr>
  </thead>
  <tbody>
    {% for instrument in instrumenten %}
      <tr class="ins-row">
        <td class="ins-cell" data-label="Instrument">
          <h3 class="ins-name">{{ instrument.name }}</h3>
        </td>

        <td class="ins-cell" data-label="Status">
          <p class="ins-status-text">{{ instrument.status | default:"Onbekend" }}</p>
        </td>

        <td class="ins-cell" data-label="Details">
          <a href="/instrumenten/{{ instrument.key }}" class="ins-details-link">
            Bekijk details
          </a>
        </td>
      </tr>
    {% endfor %}
  </tbody>
</table>
</section>

{% render 'partials/foot.liquid' %}
