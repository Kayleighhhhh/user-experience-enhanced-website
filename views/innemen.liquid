{% render 'partials/head.liquid', uitlenen: true %}

<div class="breadcrumbs">
<a href="/instrumenten">Instrumenten </a>
{% comment %} <p>" / "</p> {% endcomment %}
 {% comment %} voor beste resultaat met een before in css de / plaatsen {% endcomment %}
<a href="/instrumenten/{{ instrument.key }}">&nbsp; / {{ instrument.key }}</a>
<p>&nbsp / Innemen</p>

</div>
</header>

<main class="in-pg">
    <header class="in-head">
        <h1>Innemen</h1>
        <h2>{{ instrument.name }}</h2>
    </header>

    <form class="in-form" action="/instrumenten/{{ instrument.key }}/innemen" method="POST">
        <div class="veld">
            <label for="staat"><p>Staat bij inname</p></label>
            <select id="staat" name="staat">
                <option value="goed">In orde</option>
                <option value="schade">Nieuwe schade</option>
            </select>
        </div>

        <div class="veld">
            <label for="opm"><p>Opmerkingen</p></label>
            <textarea id="opm" name="opm" rows="3"></textarea>
        </div>

        <input type="hidden" name="id" value="{{ instrument.id }}">
        <input type="hidden" name="key" value="{{ instrument.key }}">
        
        <button type="submit" class="btn-in">
            {% if melding == 'success' %}✅ De status is aangepast!
            {% elsif melding == 'error' %}❌ Er ging iets mis!
            {% else %}Inname voltooien
            {% endif %}
        </button>
    </form>
</main>

<script type="module">

    const inneemForm = document.querySelector(".in-form")
    const inneemBtn = inneemForm.querySelector("button")

    inneemForm.addEventListener("submit", async function(event) {

        event.preventDefault()

        inneemBtn.classList.add("loading")
        inneemBtn.textContent = "laden..."

        let formData = new FormData(inneemForm);

        const response = await fetch(inneemForm.action, {
            method: inneemForm.method,
            body: new URLSearchParams(formData)
        })

        const responseData = await response.text()

        const parser = new DOMParser()
        const responseDOM = parser.parseFromString(responseData, 'text/html')

        // const newState = responseDOM.querySelector

        console.log("Loading state weghalen")
        inneemBtn.classList.remove("loading")
        inneemBtn.textContent = "✅ De status is aangepast!"
    })

</script>

{% render 'partials/foot.liquid' %}